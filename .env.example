# Database (Neon PostgreSQL)
# Get your connection string from https://console.neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/salesense?sslmode=require"

# API
API_PORT=4000

# JWT (generate strong random secrets for production)
JWT_SECRET="change-me-to-a-strong-random-secret"
JWT_REFRESH_SECRET="change-me-to-a-different-strong-random-secret"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Frontend
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000/api/v1"

# Environment
NODE_ENV="development"
